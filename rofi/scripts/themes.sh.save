#!/bin/bash
folder="/home/PSYAMEN/.config/hyprlandThemes"
mapfile -t themes < <(find "$folder" -type f \( -iname "*.conf" \) -printf "%f\t%p\n")
selected=$(printf '%s\n' "${themes[@]}" | cut -f1 | rofi -dmenu -theme ~/.config/rofi/themes/blue2.rasi -i -p "Themes")
if [ -n "$selected" ]; then
  full_path=$(printf '%s\n' "${wallpapers[@]}" | grep -F "$selected" | cut -f2 -d$'\t')
  killall Hyprland
  start-hyprand --config full_path
  echo "export theme $full_path > ~/.zshrc 
fi
